{
	"$schema": "https://turborepo.dev/schema.json",
	"envMode": "loose",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**"]
		},
		"typecheck": {
			"dependsOn": ["^typecheck"]
		},
		"dev": {
			"dependsOn": ["^build"],
			"persistent": true,
			"cache": false
		},
		"start": {
			"dependsOn": ["^build"],
			"persistent": true,
			"cache": false
		}
	}
}
